#!/bin/sh
set -eu

repo_root=$(cd "$(dirname "$0")/.." && pwd)

pattern='^(feat|fix|docs|test|refactor|chore|revert)(\([a-z0-9-]+\))?: .+'

check_commit_messages() {
    remote_sha=$1
    local_sha=$2

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    git log --no-merges --format=%s "$range" | while IFS= read -r subject; do
        printf '%s\n' "$subject" | grep -Eq "$pattern"
    done
}

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    case "$remote_ref" in
        refs/heads/*)
            check_commit_messages "$remote_sha" "$local_sha"
            ;;
    esac
done

"$repo_root/scripts/run-all-tests.sh"
