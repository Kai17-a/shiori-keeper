{
  "manifest_version": 3,
  "name": "Shiori Keeper",
  "version": "0.1.0",
  "description": "An extension for Shiori Keeper.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shiori Keeper"
  },
  "permissions": ["tabs", "storage", "bookmarks"],
  "host_permissions": ["<all_urls>"]
}
